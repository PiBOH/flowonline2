        <attribute name="edited" value="VXRlbnRlO0FTVVNJNy1LNTVWRDsyMDI2LTAzLTI1OyIwNDozNTowMiAiOzE7VXRlbnRlO0FTVVNJNy1LNTVWRDsyMDI2LTAzLTE3OyIwNDoxNjozNyAiO2RhdGkgMyBudW1lcmlpbnB1dCB0cm92YSBpbCBtYWdnaW9yZSBlIGlsIG1pbm9yZV9OTyBpZiBBTk5JREFUSS5mcHJnOzExNjE5"/>
        <attribute name="edited" value="VXRlbnRlO0FTVVNJNy1LNTVWRDsyMDI2LTA0LTAyOyIwODowNTowNiAiOzMwOzI4MDE="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <comment text="CONSEGNA&#13;&#10;&#13;&#10;dati 3 stringhe in input stampale in ordine alfabetico"/>
            <declare name="x, y, z, mg, min, med, txt" type="String" array="False" size=""/>
            <output expression="&quot;inserisci 3 frasi separandole premendo invio&quot;" newline="True"/>
            <output expression="&quot;Vai con la prima&quot;" newline="True"/>
            <input variable="x"/>
            <output expression="&quot;Vai con la seconda&quot;" newline="True"/>
            <input variable="y"/>
            <output expression="&quot;Vai con la terza&quot;" newline="True"/>
            <input variable="z"/>
            <if expression="x&lt;z">
                <then>
                    <assign variable="min" expression="x"/>
                    <assign variable="mg" expression="z"/>
                </then>
                <else>
                    <assign variable="min" expression="z"/>
                    <assign variable="mg" expression="x"/>
                </else>
            </if>
            <if expression="min&lt;y">
                <then/>
                <else>
                    <assign variable="min" expression="y"/>
                </else>
            </if>
            <if expression="mg&gt;y">
                <then/>
                <else>
                    <assign variable="mg" expression="y"/>
                </else>
            </if>
            <if expression="mg==x&amp;&amp;min==y">
                <then>
                    <assign variable="med" expression="z"/>
                </then>
                <else/>
            </if>
            <if expression="mg==x&amp;&amp;min==z">
                <then>
                    <assign variable="med" expression="y"/>
                </then>
                <else/>
            </if>
            <if expression="mg==y&amp;&amp;min==x">
                <then>
                    <assign variable="med" expression="z"/>
                </then>
                <else/>
            </if>
            <if expression="mg==y&amp;&amp;min==z">
                <then>
                    <assign variable="med" expression="x"/>
                </then>
                <else/>
            </if>
            <if expression="mg==z&amp;&amp;min==y">
                <then>
                    <assign variable="med" expression="x"/>
                </then>
                <else/>
            </if>
            <if expression="mg==z&amp;&amp;min==x">
                <then>
                    <assign variable="med" expression="y"/>
                </then>
                <else/>
            </if>
            <assign variable="txt" expression="&quot;Ecco le tue frasi disposte in ordine alfabetico:&quot;"/>
            <output expression="txt&amp;ToChar(13)&amp;ToChar(13)&amp;min&amp;ToChar(13)&amp;med&amp;ToChar(13)&amp;mg" newline="True"/>
        </body>
    </function>
</flowgorithm>
