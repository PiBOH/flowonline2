<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="Es 13"/>
        <attribute name="authors" value="PC"/>
        <attribute name="about" value="Created with Flowonline2 - PiBOH under GNU GPL v3"/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <comment text="CONSEGNA

dati 3 numeri in input stampali in ordine decrescente o crescente"/>
            <declare name="x, y, z, mg, min, med" type="Real" array="False" size=""/>
            <declare name="scelta, txt, txts" type="String" array="False" size=""/>
            <output expression="&quot;inserisci 3 numeri separandoli premendo invio&quot;&amp;ToChar(13)&amp;&quot;e io te li ordinerò in ordine crescente o decrescente&quot;" newline="True"/>
            <input variable="x"/>
            <input variable="y"/>
            <input variable="z"/>
            <if expression="x==y&amp;&amp;y==z">
                <then>
                    <assign variable="txt" expression="&quot;I numeri inseriti sono uguali quindi il programma si è quindi arrestato&quot;"/>
                    <output expression="txt" newline="True"/>
                </then>
                <else>
                    <if expression="x&lt;z">
                        <then>
                            <assign variable="min" expression="x"/>
                            <assign variable="mg" expression="z"/>
                        </then>
                        <else>
                            <assign variable="min" expression="z"/>
                            <assign variable="mg" expression="x"/>
                        </else>
                    </if>
                    <if expression="min&lt;y">
                        <then>
                        </then>
                        <else>
                            <assign variable="min" expression="y"/>
                        </else>
                    </if>
                    <if expression="mg&gt;y">
                        <then>
                        </then>
                        <else>
                            <assign variable="mg" expression="y"/>
                        </else>
                    </if>
                    <if expression="mg==x&amp;&amp;min==y">
                        <then>
                            <assign variable="med" expression="z"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <if expression="mg==x&amp;&amp;min==z">
                        <then>
                            <assign variable="med" expression="y"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <if expression="mg==y&amp;&amp;min==x">
                        <then>
                            <assign variable="med" expression="z"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <if expression="mg==y&amp;&amp;min==z">
                        <then>
                            <assign variable="med" expression="x"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <if expression="mg==z&amp;&amp;min==y">
                        <then>
                            <assign variable="med" expression="x"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <if expression="mg==z&amp;&amp;min==x">
                        <then>
                            <assign variable="med" expression="y"/>
                        </then>
                        <else>
                        </else>
                    </if>
                    <assign variable="txts" expression="&quot;ora scrivi&quot;&amp;ToChar(13)&amp;&quot;crescente (in MAIUSCLO) se vuoi i numeri in ordine crescente&quot;&amp;ToChar(13)&amp;&quot;decrescente (in MAIUSCLO) se vuoi i numeri in ordine decrescente&quot;"/>
                    <output expression="txts" newline="True"/>
                    <input variable="scelta"/>
                    <if expression="scelta&lt;&gt;&quot;CRESCENTE&quot;">
                        <then>
                            <if expression="scelta==&quot;DECRESCENTE&quot;">
                                <then>
                                    <assign variable="txt" expression="&quot;I tuoi numeri in ordine decrescente sono: &quot;"/>
                                    <output expression="txt&amp;mg&amp;&quot;, &quot;&amp;med&amp;&quot;, &quot;&amp;min" newline="True"/>
                                </then>
                                <else>
                                    <assign variable="txt" expression="&quot;ERRORE&quot;&amp;ToChar(13)&amp;&quot;Controlla di avere scritto bene l&apos;ordine in cui li volevi e poi riesegui il programma&quot;"/>
                                    <output expression="txt" newline="True"/>
                                </else>
                            </if>
                        </then>
                        <else>
                            <if expression="scelta==&quot;CRESCENTE&quot;">
                                <then>
                                    <assign variable="txt" expression="&quot;I tuoi numeri in ordine crescente sono: &quot;"/>
                                    <output expression="txt&amp;min&amp;&quot;, &quot;&amp;med&amp;&quot;, &quot;&amp;mg" newline="True"/>
                                </then>
                                <else>
                                    <assign variable="txt" expression="&quot;ERRORE&quot;&amp;ToChar(13)&amp;&quot;Controlla di avere scritto bene l&apos;ordine in cui li volevi e poi riesegui il programma&quot;"/>
                                    <output expression="txt" newline="True"/>
                                </else>
                            </if>
                        </else>
                    </if>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
